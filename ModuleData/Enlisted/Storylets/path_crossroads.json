{
  "storylets": [
    {
      "id": "path_crossroads_ranger_t4",
      "category": "path_crossroads",
      "trigger": ["is_enlisted"],
      "scope": { "context": "any" },
      "title": "{=path_cx_ranger_t4_title}The treeline keeps talking",
      "setup": "{=path_cx_ranger_t4_setup}The column rests. You read the ground without meaning to — bent grass, a turned stone. {SERGEANT} watches you do it and says nothing.",
      "options": [
        {
          "id": "commit",
          "text": "{=path_cx_ranger_t4_commit}Let them put you out front.",
          "tooltip": "{=path_cx_ranger_t4_commit_tt}Commit to ranger path. +1 Scouting focus, +10 renown.",
          "effects": [
            { "apply": "commit_path", "path": "ranger" },
            { "apply": "grant_focus_point", "skill": "Scouting", "amount": 1 },
            { "apply": "grant_renown", "amount": 10 }
          ]
        },
        {
          "id": "resist",
          "text": "{=path_cx_ranger_t4_resist}Not yet. Not the name.",
          "tooltip": "{=path_cx_ranger_t4_resist_tt}Resist ranger path. Future bumps halved.",
          "effects": [
            { "apply": "resist_path", "path": "ranger" }
          ]
        },
        {
          "id": "defer",
          "text": "{=path_cx_ranger_t4_defer}Decide later. Keep the work.",
          "tooltip": "{=path_cx_ranger_t4_defer_tt}No commitment either way.",
          "effects": []
        }
      ]
    },
    {
      "id": "path_crossroads_ranger_t6",
      "category": "path_crossroads",
      "trigger": ["is_enlisted"],
      "scope": { "context": "any" },
      "title": "{=path_cx_ranger_t6_title}First out, first back",
      "setup": "{=path_cx_ranger_t6_setup}{SERGEANT} sends you ahead without naming the task. The men shift aside when you move to mount. It is how they treat a scout now, not a soldier with a knack.",
      "options": [
        {
          "id": "commit",
          "text": "{=path_cx_ranger_t6_commit}Take the saddle. Wear the name.",
          "tooltip": "{=path_cx_ranger_t6_commit_tt}Commit to ranger path. +1 Cunning, +15 renown.",
          "effects": [
            { "apply": "commit_path", "path": "ranger" },
            { "apply": "grant_attribute_level", "attribute": "cunning", "amount": 1 },
            { "apply": "grant_renown", "amount": 15 }
