      "trigger": ["is_enlisted"],
      "scope": { "context": "any" },
      "title": "{=path_cx_ranger_t9_title}The ranger's road",
      "setup": "{=path_cx_ranger_t9_setup}{LORD_NAME} asks who reads the ground and every head turns your way. Not as a soldier who happens to scout. As the scout. The column has a shape now, and you are at the point of it.",
      "options": [
        {
          "id": "commit",
          "text": "{=path_cx_ranger_t9_commit}Answer to the name.",
          "tooltip": "{=path_cx_ranger_t9_commit_tt}Commit to ranger path. +1 unspent focus, +25 renown.",
